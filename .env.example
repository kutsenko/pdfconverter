# PDF Converter Service - Environment Variables
# Kopiere diese Datei nach .env und passe die Werte an

# ===========================================
# API Endpunkt-Konfiguration
# ===========================================
# Diese Umgebungsvariablen erlauben es, die API-Endpunkt-Pfade anzupassen

# Health Check Endpunkt
# Default: /health
HEALTH_PATH=/health

# Prometheus Metriken Endpunkt
# Default: /metrics
METRICS_PATH=/metrics

# PDF Konvertierungs-Endpunkt
# Default: /api/pdfconverter
CONVERTER_PATH=/api/pdfconverter

# ===========================================
# Weitere Konfiguration (Optional)
# ===========================================

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# Zeitzone
# TZ=Europe/Berlin

# ===========================================
# Beispiel für benutzerdefinierte Pfade
# ===========================================
# Auskommentiere und passe diese an für custom URLs:

# HEALTH_PATH=/status
# METRICS_PATH=/monitoring/metrics
# CONVERTER_PATH=/api/v1/convert
